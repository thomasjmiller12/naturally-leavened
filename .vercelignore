/node_modules
/.pnp
.pnp.*
/coverage
/.next/
/out/
/build
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.env*
.vercel
*.tsbuildinfo
next-env.d.ts
/assets/
*.zip
*.HEIC
*.heic
*.MOV

# Local-only experiments (untracked in git; playground needs deps not in package.json)
/src/app/playground/
/src/components/playground/
/new photos/
/scripts/
/.claude/
