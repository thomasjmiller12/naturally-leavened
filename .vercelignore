# Mirrors .gitignore (this file replaces it for CLI uploads) plus local-only
# untracked experiments that aren't ready to deploy.
/node_modules
/.pnp
.pnp.*
/coverage
/.next/
/out/
/build
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.env*
.vercel
*.tsbuildinfo
next-env.d.ts
/assets/
*.zip
*.HEIC
*.heic
*.MOV

# Local-only experiments. The bread-lab playground needs 3D deps (three,
# @react-three/*) that aren't in package.json, so it must stay out of the
# build. Other playground routes (e.g. class-cards) only use installed deps
# and are allowed through.
/src/app/playground/bread-lab/
/src/components/playground/BreadLabPlayground.tsx
/src/components/playground/BreadLabThreeStudy.tsx
/new photos/
/scripts/
/.claude/
